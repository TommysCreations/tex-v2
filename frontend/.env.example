# Frontend environment variables — copy to frontend/.env.local and fill in.
# Mirrors backend/.env.example structure: comment, var, blank value.
# NEXT_PUBLIC_* variables are exposed to the browser at build time.

# API
# Backend URL used by lib/api.ts. Defaults to http://localhost:8001 if unset.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001

# Auth — Clerk
# Publishable key (browser): consumed by <ClerkProvider> in app/layout.tsx.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Secret key (server-side): consumed by clerkMiddleware() in middleware.ts.
CLERK_SECRET_KEY=

# Optional Clerk URL overrides — defaults match the app routes (/sign-in,
# /sign-up). Uncomment only if you rename the route directories.
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Payments — Stripe
# Reserved. Not yet referenced in frontend code; Stripe Checkout is initiated
# server-side and the frontend redirects to the URL returned by the backend.
# Uncomment when the frontend gains direct Stripe.js integration.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Analytics — PostHog
# Reserved. posthog-js is declared in package.json but not yet wired into the
# app. Uncomment when frontend event tracking ships.
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
